{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EDITOR": "code --wait"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(git:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(node *)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx skills:*)",
      "Bash(npx playwright:*)",
      "Bash(python3:*)",
      "Bash(docker-compose exec:*)",
      "Bash(docker-compose logs:*)",
      "Bash(code --wait *)",
      "Bash(obsidian:*)",
      "Bash(~/.claude/CLAUDE.md:*)",
      "WebFetch(*)",
      "WebSearch",
      "mcp__pencil",
      "Bash(defuddle parse *)",
      "mcp__claude-in-chrome__get_page_text",
      "mcp__claude-in-chrome__read_page",
      "mcp__claude-in-chrome__tabs_context_mcp"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "language": "繁體中文",
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
