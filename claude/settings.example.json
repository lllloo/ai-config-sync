{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(git:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(node *)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx skills:*)",
      "WebFetch(*)",
      "WebSearch"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "latest"
}
